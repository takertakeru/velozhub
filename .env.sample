# Supabase (required). From your project's Settings > API page.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# Optional legacy custom-backend URL. Unused now that auth runs on Supabase.
VITE_API_URL=

# Cognito (only used if you switch the active auth provider in
# src/features/auth/provider.ts to `cognitoAuthProvider`).
# This is for AWS Cognito auth configuration
VITE_COGNITO_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=

# Analytics (optional — console logging is used by default in dev)
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=

# Your Sentry DSN (from your Sentry account)
VITE_SENTRY_DSN=

# Your Sentry organization (from your Sentry account)
VITE_SENTRY_ORG=

# Your Sentry project (from your Sentry account)
VITE_SENTRY_PROJECT=

# Your Sentry authentication token (from your Sentry account)
SENTRY_AUTH_TOKEN=
